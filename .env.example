# HomeRAG — copy this file to .env and fill in your values
#
#   cp .env.example .env

# ── Embedding ────────────────────────────────────────────────
# "local" uses sentence-transformers (no API key needed)
# "openai" uses the OpenAI API (set OPENAI_API_KEY below)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Required when EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# ── Auth ─────────────────────────────────────────────────────
# Bearer token used by the browser extension
AUTH_TOKEN=changeme
